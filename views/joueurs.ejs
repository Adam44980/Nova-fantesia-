<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Joueurs en ligne</title>
    <style>
        body { background: #0e0e0e; color: white; font-family: sans-serif; text-align: center; }
        .grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; padding: 20px; }
        .card { background: #1a1a1a; padding: 15px; border-radius: 10px; width: 120px; border: 1px solid #333; }
        img { border-radius: 5px; width: 64px; }
        h3 { font-size: 14px; margin-top: 10px; }
    </style>
</head>
<body>

    <h1>Joueurs en ligne (<%= players.length %>)</h1>

    <div class="grid">
        <% players.forEach(function(player) { %>
            <div class="card">
                <img src="https://mc-heads.net/avatar/<%= player %>" alt="avatar">
                <h3><%= player %></h3>
            </div>
        <% }); %>
    </div>

</body>
</html>