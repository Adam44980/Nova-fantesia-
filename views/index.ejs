<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova Fantasia | Serveur Minecraft Anarchie</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* STYLE MODALE ET DESIGN LISTE */
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 1000; display: flex; align-items: center; justify-content: center; }
        .modal-content { background: #1a1a1a; padding: 30px; width: 90%; max-width: 450px; border-radius: 15px; border: 1px solid #ff4d4d; position: relative; color: white; }
        .close-btn { position: absolute; top: 10px; right: 15px; cursor: pointer; font-size: 20px; color: #ff4d4d; }
        #player-list { list-style: none; padding: 0; margin-top: 20px; max-height: 350px; overflow-y: auto; }
        .player-item { display: flex; align-items: center; justify-content: space-between; padding: 12px; border-bottom: 1px solid #333; }
        .refresh-zone { text-align: center; margin-bottom: 20px; }
        .refresh-btn-manual { padding: 10px 20px; cursor: pointer; background: #ff4d4d; border: none; color: white; border-radius: 5px; font-weight: bold; transition: 0.3s; }
        .refresh-btn-manual:hover { background: #cc3d3d; }
    </style>
</head>
<body>

    <input type="checkbox" id="menu-toggle" class="menu-toggle">
    <label for="menu-toggle" class="burger-btn">☰</label>

    <div class="sidebar">
        <label for="menu-toggle" class="close-btn">✕</label>
        <div class="sidebar-brand">Nova<span>Fantasia</span></div>
        <ul class="sidebar-menu">
            <li><a href="#" class="menu-link active">🏠 Accueil</a></li>
            <li><a href="#stats" class="menu-link">📊 Statistiques</a></li>
            <li><details class="menu-dropdown"><summary>⚔️ Événement <span class="arrow">▼</span></summary><div class="dropdown-content"><a href="/arene">🔥 L'Arène</a></div></details></li>
            <li><details class="menu-dropdown"><summary>👥 Communauté <span class="arrow">▼</span></summary><div class="dropdown-content"><a href="https://discord.com/invite/9hEamDNMj" target="_blank">💬 Discord</a></div></details></li>
            <li><details class="menu-dropdown"><summary>🎮 Game Revive <span class="arrow">▼</span></summary><div class="dropdown-content"><a href="https://www.youtube.com/@adam44-y1y" target="_blank">📺 YouTube</a><a href="https://m.twitch.tv/game_revive44" target="_blank">💜 Twitch</a></div></details></li>
            <li><details class="menu-dropdown"><summary>👻 Noghosttt <span class="arrow">▼</span></summary><div class="dropdown-content"><a href="https://www.youtube.com/@noghosttt" target="_blank">📺 YouTube</a><a href="https://m.twitch.tv/noghosttt" target="_blank">💜 Twitch</a><a href="https://www.tiktok.com/@noghoos" target="_blank">🎵 TikTok</a></div></details></li>
            <li><a href="#contact" class="menu-link">✉️ Contact</a></li>
        </ul>
    </div>

    <div class="main-content">
        <section class="hero">
            <div class="hero-content">
                <div class="hero-badge">💀 SERVEUR ANARCHIE</div>
                <h1>L'Anarchie à l'<span>État Pur.</span></h1>
                <p>Pas de règles. Pas de claims. Juste de la survie, du pillage et de la liberté totale sur Nova Fantasia.</p>
                <div class="server-ip-box" onclick="copyIP()">
                    <div class="ip-left">
                        <span class="ip-icon">🖥️</span>
                        <span class="ip-text" id="server-ip">novafantasia.falixsrv.me</span>
                    </div>
                    <span class="copy-badge" id="copy-badge">📋 Copier l'IP</span>
                </div>
            </div>
        </section>

        <section id="stats" class="stats-section">
            <div class="refresh-zone">
                <button class="refresh-btn-manual" onclick="manualRefresh()">🔄 Actualiser tout maintenant</button>
            </div>
            <div class="stats-container">
                <div class="stat-card">
                    <div class="stat-icon-wrap">📡</div>
                    <h3>Statut</h3>
                    <p id="status-text">—</p>
                </div>
                <div class="stat-card" onclick="showPlayers()" style="cursor: pointer;">
                    <div class="stat-icon-wrap">👥</div>
                    <h3>Joueurs en ligne</h3>
                    <p id="players-text">— / —</p>
                </div>
                <div class="stat-card">
                    <div class="stat-icon-wrap">🔖</div>
                    <h3>Version</h3>
                    <p id="version-text">—</p>
                </div>
            </div>
        </section>

        <footer id="contact">
            <div class="footer-content" style="padding: 50px; text-align: center;">
                <div class="footer-brand">Nova<span>Fantasia</span></div>
                <p>Une question ou un partenariat ?</p>
                <a href="mailto:novafantesia@gmail.com" class="email-btn" style="color: #ff4d4d; font-size: 1.5rem; text-decoration: none;">
                    ✉️ novafantesia@gmail.com
                </a>
                <p class="copyright" style="margin-top: 30px;">&copy; 2026 Nova Fantasia. Non affilié à Mojang.</p>
            </div>
        </footer>
    </div>

    <div id="playerModal" class="modal" style="display:none;">
        <div class="modal-content">
            <span class="close-btn" onclick="closeModal()">✕</span>
            <h3>Joueurs connectés</h3>
            <ul id="player-list"></ul>
        </div>
    </div>

    <script>
        const SERVER_IP = 'novafantasia.falixsrv.me';
        let playerList = []; 

        async function fetchStats() {
            try {
                const res = await fetch(`https://api.mcsrvstat.us/3/${SERVER_IP}`);
                const data = await res.json();
                if (data.online) {
                    playerList = data.players?.list || [];
                    document.getElementById('status-text').textContent = 'En ligne';
                    document.getElementById('players-text').textContent = `${data.players.online} / ${data.players.max}`;
                    document.getElementById('version-text').textContent = data.version;
                }
            } catch (e) { console.error('Erreur API'); }
        }

        // Générateur de barres de ping
        function getPingBars() {
            const barsCount = Math.floor(Math.random() * 4) + 1;
            let html = '<span style="display:inline-flex; gap: 2px; align-items: flex-end; margin-left: 10px;">';
            for (let i = 0; i < 4; i++) {
                const color = (i < barsCount) ? (barsCount > 2 ? '#4caf50' : '#ff9800') : '#333';
                html += `<span style="width: 4px; height: ${5 + (i * 3)}px; background: ${color};"></span>`;
            }
            return html + '</span>';
        }

        function showPlayers() {
            const listElement = document.getElementById('player-list');
            listElement.innerHTML = ''; 
            if (playerList.length === 0) {
                listElement.innerHTML = '<li>Aucun joueur en ligne.</li>';
            } else {
                playerList.forEach(player => {
                    const name = (typeof player === 'object' && player.name) ? player.name : player;
                    listElement.innerHTML += `
                        <li class="player-item">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span style="color: #ff4d4d;">🔧</span> 
                                <span style="font-weight: bold;">${name}</span>
                            </div>
                            ${getPingBars()}
                        </li>`;
                });
            }
            document.getElementById('playerModal').style.display = 'flex';
        }

        async function manualRefresh() {
            await fetchStats();
            alert("Données mises à jour !");
        }

        function closeModal() { document.getElementById('playerModal').style.display = 'none'; }
        function copyIP() { navigator.clipboard.writeText(SERVER_IP); alert('IP copiée !'); }

        fetchStats();
    </script>
</body>
</html>