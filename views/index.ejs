    <script>
        const SERVER_IP = 'novafantasia.falixsrv.me';
        const REFRESH_INTERVAL = 60;
        let countdown = REFRESH_INTERVAL;
        let countdownTimer;

        async function fetchStats() {
            const icon = document.getElementById('refresh-icon');
            icon.style.transform = 'rotate(360deg)';
            try {
                const res = await fetch(`https://api.mcsrvstat.us/3/${SERVER_IP}`);
                const data = await res.json();
                if (data.online) {
                    document.getElementById('status-text').textContent = 'En ligne';
                    document.getElementById('players-text').textContent = `${data.players.online} / ${data.players.max}`;
                    document.getElementById('version-text').textContent = data.version;
                }
            } catch (e) {
                console.error('Erreur API');
            }
            countdown = REFRESH_INTERVAL;
        }

        function copyIP() {
            navigator.clipboard.writeText(SERVER_IP);
            alert('IP copiée !');
        }

        // Initialisation
        fetchStats();
        setInterval(() => {
            if(countdown > 0) {
                countdown--;
                document.getElementById('countdown').textContent = countdown;
            } else {
                fetchStats();
            }
        }, 1000);
    </script>

    <div style="height: 100px;"></div>
    </body>
</html>