        <section id="stats" class="stats-section">
            <div class="section-header">
                <h2>État du <span>Serveur</span></h2>
                <div class="refresh-info">
                    <span>Actualisation dans <strong id="countdown">60</strong>s</span>
                    <button class="refresh-btn" onclick="fetchStats()">
                        <span id="refresh-icon">🔄</span>
                    </button>
                </div>
            </div>

            <div class="stats-container">
                <div class="stat-card">
                    <div class="stat-icon-wrap" id="status-icon">📡</div>
                    <h3>Statut</h3>
                    <p id="status-text">—</p>
                </div>
                <div class="stat-card">
                    <div class="stat-icon-wrap">👥</div>
                    <h3>Joueurs en ligne</h3>
                    <p id="players-text">— / —</p>
                </div>
                <div class="stat-card">
                    <div class="stat-icon-wrap">🔖</div>
                    <h3>Version</h3>
                    <p id="version-text">—</p>
                </div>
                <div class="stat-card">
                    <div class="stat-icon-wrap">🔌</div>
                    <h3>IP de connexion</h3>
                    <p style="font-size:14px;">novafantasia.falixsrv.me</p>
                </div>
            </div>
        </section>

        <section class="join-section">
            <div class="join-content">
                <h2>Prêt à rejoindre le chaos ?</h2>
                <p>Lance Minecraft, ajoute le serveur et plonge dans l'anarchie totale.</p>
                <div class="join-steps">
                    <div class="step"><span class="step-num">1</span><p>Minecraft Java</p></div>
                    <div class="step"><span class="step-num">2</span><p>Multijoueur</p></div>
                    <div class="step"><span class="step-num">3</span><p>Ajouter serveur</p></div>
                    <div class="step"><span class="step-num">4</span><p>Se connecter</p></div>
                </div>
            </div>
        </section>

        <footer id="contact">
            <div class="footer-content">
                <div class="footer-brand">Nova<span>Fantasia</span></div>
                <p>Une question ou un partenariat ?</p>
                <a href="mailto:novafantesia@gmail.com" class="email-btn">✉️ novafantesia@gmail.com</a>
                <div class="footer-links">
                    <a href="https://discord.com/invite/9hEamDNMj" target="_blank">Discord</a>
                    <a href="https://www.youtube.com/@adam44-y1y" target="_blank">YouTube</a>
                    <a href="https://m.twitch.tv/game_revive44" target="_blank">Twitch</a>
