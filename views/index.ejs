    <!-- CONTENU PRINCIPAL -->
    <div class="main-content">

        <!-- HERO -->
        <section class="hero">
            <div class="hero-content">
                <div class="hero-badge">💀 SERVEUR ANARCHIE</div>
                <h1>L'Anarchie à l'<span>État Pur.</span></h1>
                <p>Pas de règles. Pas de claims. Juste de la survie, du pillage et de la liberté totale sur Nova Fantasia.</p>

                <div class="server-ip-box" onclick="copyIP()">
                    <div class="ip-left">
                        <span class="ip-icon">🖥️</span>
                        <span class="ip-text" id="server-ip">novafantasia.falixsrv.me</span>
                    </div>
                    <span class="copy-badge" id="copy-badge">📋 Copier l'IP</span>
                </div>

                <div class="hero-live">
                    <span class="live-dot" id="hero-dot"></span>
                    <span id="hero-players">Chargement...</span>
                </div>
            </div>
        </section>

        <!-- STATS -->
        <section id="stats" class="stats-section">
            <div class="section-header">
                <h2>État du <span>Serveur</span></h2>
                <div class="refresh-info">
                    <span>Actualisation dans <strong id="countdown">60</strong>s</span>
                    <button class="refresh-btn" onclick="fetchStats()" title="Actualiser maintenant">
                        <span id="refresh-icon">🔄</span>
                    </button>
                </div>
            </div>

            <div class="stats-container">
                <div class="stat-card">
                    <div class="stat-icon-wrap" id="status-icon">📡</div>
                    <h3>Statut</h3>
                    <p id="status-text">—</p>
                </div>
                <div class="stat-card">
                    <div class="stat-icon-wrap">👥</div>
                    <h3>Joueurs en ligne</h3>
                    <p id="players-text">— / —</p>
                </div>
                <div class="stat-card">
                    <div class="stat-icon-wrap">🔖</div>
                    <h3>Version</h3>
                    <p id="version-text">—</p>
                </div>
                <div class="stat-card">
                    <div class="stat-icon-wrap">🔌</div>
                    <h3>IP de connexion</h3>
                    <p style="font-size:14px;">novafantasia.falixsrv.me</p>
                </div>
            </div>
        </section>

        <!-- REJOINDRE -->
        <section class="join-section">
            <div class="join-content">
                <h2>Prêt à rejoindre le chaos ?</h2>
                <p>Lance Minecraft, ajoute le serveur et plonge dans l'anarchie totale. Aucune inscription requise.</p>
                <div class="join-steps">
                    <div class="step"><span class="step-num">1</span><p>Lance <strong>Minecraft Java</strong></p></div>
                    <div class="step-arrow">→</div>
                    <div class="step"><span class="step-num">2</span><p>Va dans <strong>Multijoueur</strong></p></div>
                    <div class="step-arrow">→</div>
                    <div class="step"><span class="step-num">3</span><p>Ajoute <strong>l'IP</strong> du serveur</p></div>
                    <div class="step-arrow">→</div>
                    <div class="step"><span class="step-num">4</span><p><strong>Connecte-toi</strong> et survive !</p></div>
                </div>
            </div>
        </section>

        <!-- FOOTER -->
        <footer id="contact">
            <div class="footer-content">
                <div class="footer-brand">Nova<span>Fantasia</span></div>
                <p>Une question, un bug à signaler ou une proposition de partenariat ?</p>
                <a href="mailto:novafantesia@gmail.com" class="email-btn">✉️ novafantesia@gmail.com</a>
                <div class="footer-links">
                    <a href="https://discord.com/invite/9hEamDNMj" target="_blank" title="Discord">💬</a>
                    <a href="https://www.youtube.com/@adam44-y1y" target="_blank" title="YouTube">
                        <svg class="brand-icon-footer yt"><use href="#icon-yt"/></svg>
                    </a>
                    <a href="https://m.twitch.tv/game_revive44" target="_blank" title="Twitch">
