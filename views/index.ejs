<!-- MODALE JOUEURS -->
<div id="playerModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title"><span style="color:var(--primary-color);">👥</span> Survivants en ligne</h3>
            <span class="close-btn" onclick="closeModal()">✕</span>
        </div>
        <ul id="player-list"></ul>
    </div>
</div>

<!-- TOASTS -->
<div id="toast-container" class="toast-container"></div>

<!-- BACK TO TOP -->
<button id="backToTop" onclick="scrollToTop()">↑</button>

<script>
    /* ============================================
       CONFIGURATION
       ============================================ */
    const SERVER_IP  = 'novafantasia.falixsrv.me';
    const EMAIL_ADDR = 'novafantesia@gmail.com';
    let playerList = [];

    /* ============================================
       1. MOTEUR DE PARTICULES (CENDRES ANIMÉES)
       ============================================ */
    const canvas = document.getElementById('particle-canvas');
    const ctx    = canvas.getContext('2d');
    let particles = [];

    function resizeCanvas() {
        canvas.width  = window.innerWidth;
        canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', () => { resizeCanvas(); particles = []; initParticles(); });
    resizeCanvas();

    class Particle {
        constructor() { this.reset(true); }
        reset(random = false) {
            this.x      = Math.random() * canvas.width;
            this.y      = random ? Math.random() * canvas.height : canvas.height + 10;
            this.size   = Math.random() * 2.5 + 0.5;
            this.speedX = (Math.random() - 0.5) * 0.8;
            this.speedY = -(Math.random() * 1.5 + 0.4);
            this.life   = 1.0;
            this.decay  = Math.random() * 0.004 + 0.002;
            this.hue    = Math.random() > 0.6 ? 0 : 25;   // rouge ou orangé
        }
        update() {
            this.x    += this.speedX;
            this.y    += this.speedY;
            this.life -= this.decay;
            if (this.life <= 0 || this.y < -10) this.reset();
        }
        draw() {
            ctx.globalAlpha = this.life * 0.7;
            ctx.fillStyle   = `hsl(${this.hue}, 90%, 55%)`;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fill();
        }
    }

    function initParticles() {
        for (let i = 0; i < 65; i++) particles.push(new Particle());
    }
    function animateParticles() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => { p.update(); p.draw(); });
        ctx.globalAlpha = 1;
        requestAnimationFrame(animateParticles);
    }
    initParticles();
    animateParticles();

    /* ============================================
       2. API MINECRAFT — STATISTIQUES SERVEUR
       ============================================ */
    async function fetchStats() {
        try {
            const res  = await fetch(`https://api.mcsrvstat.us/3/${SERVER_IP}?nocache=${Date.now()}`);
            const data = await res.json();
            const statusEl  = document.getElementById('status-text');
            const playersEl = document.getElementById('players-text');
            const versionEl = document.getElementById('version-text');

            if (data.online) {
                playerList = data.players?.list || [];
                statusEl.textContent  = '✅ En ligne';
                statusEl.style.color  = '#4caf50';
                statusEl.style.fontSize = '1.6rem';
                playersEl.textContent = `${data.players.online} / ${data.players.max}`;
                if (data.version) versionEl.textContent = data.version;
            } else {
                statusEl.textContent  = '🔴 Hors Ligne';
                statusEl.style.color  = '#ff4d4d';
                statusEl.style.fontSize = '1.6rem';
                playersEl.textContent = '0 / 0';
                playerList = [];
            }
        } catch (e) {
            console.error('Erreur API Minecraft:', e);
            document.getElementById('status-text').textContent = '⚠️ Erreur';
        }
    }

    async function manualRefresh() {
        const btn = document.getElementById('refresh-btn');
        btn.innerHTML  = '<span>⏳</span> Synchronisation...';
        btn.disabled   = true;
        btn.style.opacity = '0.65';

        await fetchStats();
        if (document.getElementById('playerModal').style.display === 'flex') showPlayers();

        btn.innerHTML    = '<span>✔️</span> Actualisé !';
        btn.style.background = '#4caf50';

        setTimeout(() => {
            btn.innerHTML    = '<span>🔄</span> Forcer l\'actualisation';
            btn.disabled     = false;
            btn.style.opacity = '1';
            btn.style.background = '';
        }, 2200);
    }

    // Auto-refresh toutes les 60 secondes
    setInterval(() => {
        fetchStats();
        if (document.getElementById('playerModal').style.display === 'flex') showPlayers();
    }, 60000);

    /* ============================================
       3. MODALE JOUEURS
       ============================================ */
    function getPingBars(bars = null) {
        const count = bars !== null ? bars : Math.floor(Math.random() * 4) + 1;
        let html = '<div style="display:flex; gap:3px; align-items:flex-end; height:16px;">';
        for (let i = 0; i < 4; i++) {
            const active = i < count;
            const color  = active ? (count > 2 ? '#4caf50' : count === 2 ? '#ffeb3b' : '#ff4d4d') : '#2a2a2a';
            const h      = 5 + i * 3;
            html += `<span style="width:4px;height:${h}px;background:${color};border-radius:2px;display:inline-block;"></span>`;
        }
        return html + '</div>';
    }

    function showPlayers() {
        const listEl = document.getElementById('player-list');
        listEl.innerHTML = '';

        if (!playerList || playerList.length === 0) {
            listEl.innerHTML = `
                <div style="text-align:center;padding:45px 20px;color:var(--text-muted);">
                    <span style="font-size:3rem;display:block;margin-bottom:12px;">💀</span>
                    <strong style="display:block;margin-bottom:6px;">Personne en vie</strong>
                    Le serveur est vide — ou tous les joueurs sont cachés.
                </div>`;
        } else {
            playerList.forEach(player => {
                const name = (typeof player === 'object' && player.name) ? player.name : player;
                const li = document.createElement('li');
                li.className = 'player-item';
                li.innerHTML = `
                    <div class="player-info">
                        <img src="https://mc-heads.net/avatar/${name}/36" alt="${name}" width="36" height="36">
                        <span class="player-name">${name}</span>
                    </div>
                    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px;">
                        <span style="font-size:0.68rem;color:#555;text-transform:uppercase;letter-spacing:1px;">Ping</span>
                        ${getPingBars()}
                    </div>`;
                listEl.appendChild(li);
            });
        }

        document.getElementById('playerModal').style.display = 'flex';
    }

    function closeModal() { document.getElementById('playerModal').style.display = 'none'; }
    window.addEventListener('click', e => {
        if (e.target === document.getElementById('playerModal')) closeModal();
    });
    window.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    /* ============================================
       4. TOAST — SYSTÈME NOTIFICATIONS
       ============================================ */
    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = `toast ${type}`;
        const icon = type === 'success' ? '✔️' : '❌';
        toast.innerHTML = `<span style="font-size:1.1rem;">${icon}</span> ${message}`;
        container.appendChild(toast);
        // Force reflow pour lancer l'animation
        void toast.offsetWidth;

        setTimeout(() => {
            toast.classList.add('hide');
            setTimeout(() => toast.remove(), 500);
        }, 4000);
    }

    /* ============================================
       5. COPIE IP ET EMAIL
       ============================================ */
    function copyIP() {
        navigator.clipboard.writeText(SERVER_IP)
            .then(() => showToast(`IP copiée : <b>${SERVER_IP}</b>`, 'success'))
            .catch(() => showToast('Impossible de copier. Copie manuelle : ' + SERVER_IP, 'error'));
    }

    function copyEmail() {
        navigator.clipboard.writeText(EMAIL_ADDR)
            .then(() => showToast(`Email copié : <b>${EMAIL_ADDR}</b>`, 'success'))
            .catch(() => showToast('Email : ' + EMAIL_ADDR, 'error'));
    }

    /* ============================================
       6. FORMULAIRE CONTACT
       ============================================ */
    function submitForm() {
        const pseudo  = document.getElementById('f-pseudo').value.trim();
        const email   = document.getElementById('f-email').value.trim();
        const type    = document.getElementById('f-type').value;
        const message = document.getElementById('f-message').value.trim();

        // Validation basique
        if (!pseudo) {
            highlightError('f-pseudo', 'Entre ton pseudo Minecraft !');
            return;
        }
        if (!type) {
            highlightError('f-type', 'Sélectionne une catégorie !');
            return;
        }
        if (message.length < 20) {
            highlightError('f-message', 'Message trop court (min. 20 caractères) !');
            return;
        }

        // Simulation envoi (lien mailto)
        const subject = encodeURIComponent(`[${type.toUpperCase()}] ${pseudo} - Nova Fantasia`);
        const body    = encodeURIComponent(`Pseudo: ${pseudo}\nEmail: ${email || 'Non fourni'}\nCatégorie: ${type}\n\n${message}`);
        window.location.href = `mailto:${EMAIL_ADDR}?subject=${subject}&body=${body}`;

        // Feedback utilisateur
        showToast('📨 Ouverture du client mail...', 'success');

        // Reset form
        setTimeout(() => {
            document.getElementById('f-pseudo').value  = '';
            document.getElementById('f-email').value   = '';
            document.getElementById('f-type').value    = '';
            document.getElementById('f-message').value = '';
        }, 800);
    }

    function highlightError(id, msg) {
        const el = document.getElementById(id);
        el.style.borderColor = 'var(--primary-color)';
        el.style.boxShadow = '0 0 0 3px rgba(255,77,77,0.15)';
        el.style.animation = 'shake 0.4s ease';
        showToast(msg, 'error');
        setTimeout(() => {
            el.style.borderColor = '';
            el.style.boxShadow   = '';
            el.style.animation   = '';
        }, 2000);
    }

    /* ============================================
       7. FAQ ACCORDION
       ============================================ */
    function toggleFaq(element) {
        const parent = element.parentElement;
        const isOpen = parent.classList.contains('active');
        // Ferme tous
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
        // Ouvre si était fermé
        if (!isOpen) parent.classList.add('active');
    }

    /* ============================================
       8. SCROLL — REVEAL + SIDEBAR ACTIVE + BACK TO TOP
       ============================================ */
    function revealOnScroll() {
        const triggers = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
        triggers.forEach(el => {
            if (el.getBoundingClientRect().top < window.innerHeight - 80) {
                el.classList.add('active');
            }
        });

        // Active menu link en fonction de la section visible
        const sections = document.querySelectorAll('section[id]');
        let current = '';
        sections.forEach(sec => {
            if (window.scrollY >= sec.offsetTop - 200) current = sec.getAttribute('id');
        });
        document.querySelectorAll('.menu-link').forEach(link => {
            link.classList.remove('active');
            const href = link.getAttribute('href');
            if (href === '#' + current || (current === 'home' && href === '#')) {
                link.classList.add('active');
            }
        });

        // Back to top
        const btn = document.getElementById('backToTop');
        if (window.scrollY > 450) btn.classList.add('visible');
        else btn.classList.remove('visible');
    }

    function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }

    window.addEventListener('scroll', revealOnScroll, { passive: true });

    /* MENU MOBILE — FERMER EN CLIQUANT UN LIEN */
    document.querySelectorAll('.menu-link').forEach(link => {
        link.addEventListener('click', () => {
            document.getElementById('menu-toggle').checked = false;
        });
    });

    /* ============================================
       9. INITIALISATION AU CHARGEMENT
       ============================================ */
    window.addEventListener('load', () => {
        fetchStats();
        revealOnScroll();
    });

    /* SMOOTH SCROLL POUR LES LIENS ANCHOR */
    document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
            const target = document.querySelector(a.getAttribute('href'));
            if (target) {
                e.preventDefault();
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });
</script>
</body>
</html>