<script>
const SERVER_IP='novafantasia.falixsrv.me';
const REFRESH_INTERVAL=60;
let countdown=REFRESH_INTERVAL;
let countdownTimer;
async function fetchStats(){
try{
const res=await fetch(`https://api.mcsrvstat.us/3/${SERVER_IP}`);
const data=await res.json();
if(data.online){
document.getElementById('status-icon').textContent='🟢';
document.getElementById('status-text').textContent='En ligne';
document.getElementById('players-text').textContent=`${data.players.online} / ${data.players.max}`;
document.getElementById('version-text').textContent=data.version??'Inconnue';
document.getElementById('hero-players').textContent=`${data.players.online} en ligne`;
}else{
document.getElementById('status-icon').textContent='🔴';
document.getElementById('status-text').textContent='Hors ligne';
}}catch(e){console.error(e);}
countdown=REFRESH_INTERVAL;
}
function copyIP(){
navigator.clipboard.writeText(SERVER_IP);
const badge=document.getElementById('copy-badge');
badge.textContent='✅ Copié !';
setTimeout(()=>{badge.textContent='📋 Copier l\'IP';},2000);
}
function startEventTimer(){
const targetDate=new Date('2026-07-03T18:00:00').getTime(); 
function updateTimer(){
const now=new Date().getTime();
const diff=targetDate-now;
const d=Math.floor(diff/(1000*60*60*24));
const h=Math.floor((diff%(1000*60*60*24))/(1000*60*60));
document.getElementById('event-timer').textContent=d+"j "+h+"h";
}
updateTimer();
setInterval(updateTimer,60000);
}
fetchStats();
startEventTimer();
</script>
